{
  "manifest_version": 3,
  "name": "Horpen — Recreate any image",
  "short_name": "Horpen",
  "version": "0.1.0",
  "description": "Right-click any image on the web and recreate it with your trained characters or products. Powered by horpen.ai.",

  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },

  "action": {
    "default_title": "Horpen",
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },

  "background": {
    "service_worker": "service-worker.js",
    "type": "module"
  },

  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_idle",
      "all_frames": false
    }
  ],

  "permissions": [
    "contextMenus",
    "storage",
    "activeTab",
    "tabs",
    "scripting"
  ],

  "host_permissions": [
    "https://api.horpen.ai/*",
    "https://horpen.ai/*",
    "http://localhost:8000/*",
    "http://localhost:3000/*",
    "<all_urls>"
  ],

  "externally_connectable": {
    "matches": [
      "https://horpen.ai/*",
      "https://www.horpen.ai/*",
      "http://localhost:3000/*"
    ]
  },

  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self'"
  }
}
